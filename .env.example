# ─── Tender Intelligence — Environment Variables ───────────────────────
# Copy this file to `.env` and adjust values for your environment.

# Database (SQLite for local dev; switch to PostgreSQL for production)
DATABASE_URL="file:./db/custom.db"
# PostgreSQL example (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/tender_intelligence?schema=public"

# NextAuth.js (uncomment and configure when wiring authentication)
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Z.ai SDK configuration (for AI features: summarization, risk scoring, semantic search)
# The SDK reads ~/.z-ai-config or /etc/.z-ai-config automatically.
# Create that file with: {"baseUrl":"https://internal-api.z.ai/v1","apiKey":"...","token":"..."}
# When unavailable, the platform gracefully falls back to deterministic heuristics.
